# Discord Librarian Bot 환경 변수
# 이 파일을 복사해서 .env 로 저장하세요

# ── Discord (사서봇) ─────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token-here
# 슬래시 커맨드 즉시 동기화용 (비우면 전체 동기화, 최대 1시간 소요)
DISCORD_GUILD_ID=

# ── Discord (AI 사서봇) ──────────────────────
AI_BOT_TOKEN=your-ai-bot-token-here

# ── Gemini API ───────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── 설정 ─────────────────────────────────────
DATABASE_PATH=librarian_bot.db
UPLOAD_DIR=uploads
MAX_FILE_SIZE=26214400
ADMIN_USER_IDS=123456789
