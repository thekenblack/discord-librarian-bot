# Discord Librarian Bot 환경 변수
# 이 파일을 복사해서 .env 로 저장하세요: cp env.example .env

# ── Discord (라이브러리 봇) ──────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token-here
# 슬래시 커맨드 즉시 동기화용 (비우면 전체 동기화, 최대 1시간 소요)
DISCORD_GUILD_ID=

# ── Discord (AI 사서봇) ──────────────────────
AI_BOT_TOKEN=your-ai-bot-token-here
AI_NAME=사서봇
AI_STATUS_TEXT=Library

# ── Gemini API ───────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── 후원 ─────────────────────────────────────
LIGHTNING_ADDRESS=

# ── 설정 ─────────────────────────────────────
TZ=Asia/Seoul
ADMIN_USER_IDS=123456789
