# Discord Librarian Bot 환경 변수
# 이 파일을 복사해서 .env 로 저장하세요: cp env.example .env

# ── Discord (라이브러리 봇) ──────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── Discord (AI 사서봇) ──────────────────────
AI_BOT_TOKEN=
AI_NAME=비트쨩
AI_CREATOR=Ken
AI_COMMUNITY=시타델

# ── Gemini API ───────────────────────────────
GEMINI_API_KEY=

# ── Lightning / Blink (충전 시스템) ───────────
LIGHTNING_ADDRESS=
BLINK_API_KEY=
MIN_CHARGE_SAT=1
INVOICE_EXPIRE=3600

# ── 자발적 발화 ──────────────────────────────
SPONTANEOUS_CHANNEL_ID=
SPONTANEOUS_QUIET_HOURS=3
SPONTANEOUS_CHECK_HOURS=3
SPONTANEOUS_CHANCE=25

# ── 설정 ─────────────────────────────────────
TZ=Asia/Seoul
ADMIN_USER_IDS=
